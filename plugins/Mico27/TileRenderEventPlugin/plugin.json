{
  "type": "enginePlugin",
  "name": "Tile Render Event Plugin",
  "author": "Mico27",
  "url": "https://github.com/Mico27/GBS-TileRenderEventPlugin",
  "description": "Can register scripts to be run when a row/column/whole screen is rendered.",
  "license": "MIT",
  "version": "4.2.3",
  "gbsVersion": ">=4.2.3",
  "engineAltRules": [
    {
      "when": {
        "additionalPlugins": [
          "Mico27/MetaTilePlugin",
          "Mico27/ScreenScrollPlugin"
        ]
      },
      "use": "M_Scr"
    },
    {
      "when": {
        "additionalPlugins": [
          "MetaTilePlugin",
          "ScreenScrollPlugin"
        ]
      },
      "use": "M_Scr"
    },
    {
      "when": {
        "additionalPlugins": [
          "Mico27/MetaTilePlugin"
        ]
      },
      "use": "M"
    },
    {
      "when": {
        "additionalPlugins": [
          "MetaTilePlugin"
        ]
      },
      "use": "M"
    },
    {
      "when": {
        "additionalPlugins": [
          "Mico27/ScreenScrollPlugin"
        ]
      },
      "use": "Scr"
    },
    {
      "when": {
        "additionalPlugins": [
          "ScreenScrollPlugin"
        ]
      },
      "use": "Scr"
    }
  ]
}